# Copy to .env.local (cp .env.local.example .env.local) and fill in values.
# Step-by-step instructions live in docs/SETUP.md.

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Firebase client SDK (safe to ship to the browser) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin SDK (server-only; never expose) ---
# From a service-account JSON: project_id, client_email, private_key.
# Paste the private key as-is; newlines will be decoded at runtime.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# --- Stripe Payment Link (currently unused; kept for future re-enable) ---
# Paste the full Payment Link URL from the Stripe dashboard
# (Products → your product → Payment Links).
NEXT_PUBLIC_STRIPE_PAYMENT_LINK_SLEEP_TEST=
